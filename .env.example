# =============================================================================
# Vehicle Tracker — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# Never commit real secrets. Use strong random values in production.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=tracker
POSTGRES_PASSWORD=change_me_use_strong_password
POSTGRES_DB=vehicle_tracker
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://tracker:change_me_use_strong_password@localhost:5432/vehicle_tracker

# Connection pool (optional — defaults shown)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# --- Redis ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_KEY_PREFIX=tracker:session:

# --- Redis Streams / Telemetry ---
REDIS_STREAM_KEY=tracker:events
REDIS_DEAD_LETTER_STREAM_KEY=tracker:dead-letter
REDIS_STREAM_MAXLEN=100000
REDIS_STREAM_READ_COUNT=10
REDIS_STREAM_BLOCK_MS=5000
REDIS_CONSUMER_GROUP=tracker-workers
REDIS_CONSUMER_NAME=worker-1

# --- Worker retry / DLQ ---
WORKER_MAX_RETRIES=3
WORKER_RETRY_BACKOFF_MS=500

# --- Backend ---
BACKEND_PORT=8000
APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=json
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000

# --- Auth / JWT ---
JWT_SECRET_KEY=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=false
LOGIN_RATE_LIMIT=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

# --- Gateway ---
GATEWAY_TCP_HOST=0.0.0.0
GATEWAY_TCP_PORT=5023
GATEWAY_HEALTH_PORT=5024
GATEWAY_MAX_CONNECTIONS=10000
GATEWAY_CONNECTION_IDLE_TIMEOUT=300

# --- Worker health ---
WORKER_HEALTH_PORT=9100

# Note: use GATEWAY_HEALTH_PORT and WORKER_HEALTH_PORT per service.
# Do not use a generic HEALTH_PORT — it conflicts between containers.

# --- Observability (optional) ---
METRICS_ENABLED=true
HEALTH_HOST=0.0.0.0

# --- Frontend ---
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
INTERNAL_API_URL=http://backend:8000

# Google Maps (Monitoring / MapProvider)
# Crie a chave em https://console.cloud.google.com/ — Maps JavaScript API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Map ID opcional (Cloud Console → Map Management) — necessário para AdvancedMarker
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
